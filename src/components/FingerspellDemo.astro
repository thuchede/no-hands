---
/**
 * Demo 2: ASL fingerspelling -> live subtitles.
 * Classifies normalized hand landmarks with a kNN over samples recorded
 * on the /calibrate page (localStorage, else bundled JSON).
 */
import { withBase } from "../lib/paths";
---

<div class="fingerspell-demo" data-fingerspell-demo>
	<div class="viewport">
		<video></video>
		<canvas></canvas>
		<p class="status">Camera starting…</p>
		<div class="letter-chip" hidden>
			<span class="letter">A</span>
			<svg viewBox="0 0 36 36" class="progress-ring">
				<circle cx="18" cy="18" r="15.5"></circle>
			</svg>
		</div>
	</div>
	<div class="subtitles">
		<p class="subtitle-text" aria-live="polite">&nbsp;</p>
	</div>
	<p class="samples-warning" hidden>
		No training samples found — open <a href={withBase("calibrate")}>/calibrate</a> and record your alphabet first.
	</p>
</div>

<script>
	import { acquireCamera, attachPreview } from "../lib/camera";
	import { subscribeVision } from "../lib/vision";
	import { syncCanvasSize, clearCanvas, drawHands } from "../lib/draw";
	import { onSlideVisible } from "../lib/deck";
	import { normalizeLandmarks, KnnClassifier, LetterTyper, loadSamples } from "../lib/fingerspell";

	const RING_CIRCUMFERENCE = 2 * Math.PI * 15.5;

	for (const root of document.querySelectorAll<HTMLElement>("[data-fingerspell-demo]")) {
		const video = root.querySelector("video")!;
		const canvas = root.querySelector("canvas")!;
		const status = root.querySelector<HTMLElement>(".status")!;
		const letterChip = root.querySelector<HTMLElement>(".letter-chip")!;
		const letterEl = letterChip.querySelector<HTMLElement>(".letter")!;
		const ringCircle = letterChip.querySelector<SVGCircleElement>("circle")!;
		const subtitleText = root.querySelector<HTMLElement>(".subtitle-text")!;
		const samplesWarning = root.querySelector<HTMLElement>(".samples-warning")!;

		const typer = new LetterTyper((state) => {
			subtitleText.textContent = state.text || " ";
			letterChip.hidden = !state.candidate;
			if (state.candidate) {
				letterEl.textContent = state.candidate;
				ringCircle.style.strokeDasharray = `${RING_CIRCUMFERENCE}`;
				ringCircle.style.strokeDashoffset = `${RING_CIRCUMFERENCE * (1 - state.progress)}`;
			}
		});

		let unsubscribe: (() => void) | null = null;
		let camera: ReturnType<typeof acquireCamera> | null = null;

		const start = async () => {
			const samples = await loadSamples();
			samplesWarning.hidden = samples.length > 0;
			const classifier = new KnnClassifier(samples);
			try {
				camera = acquireCamera();
				await attachPreview(video, await camera.stream);
				status.hidden = true;
				unsubscribe = subscribeVision({ hands: true }, (results) => {
					syncCanvasSize(canvas, results.video);
					clearCanvas(canvas);
					if (results.hands) drawHands(canvas, results.hands);

					let prediction = null;
					const landmarks = results.hands?.landmarks[0];
					if (landmarks && samples.length > 0) {
						const isLeft = results.hands!.handedness[0]?.[0]?.categoryName === "Left";
						prediction = classifier.classify(normalizeLandmarks(landmarks, isLeft));
					}
					typer.feed(prediction, results.timestamp);
				});
			} catch (err) {
				status.hidden = false;
				status.textContent = `Camera unavailable: ${err instanceof Error ? err.message : err}`;
			}
		};

		const stop = () => {
			unsubscribe?.();
			unsubscribe = null;
			camera?.release();
			camera = null;
			video.srcObject = null;
			clearCanvas(canvas);
			typer.clear();
			status.hidden = false;
			status.textContent = "Camera starting…";
		};

		onSlideVisible(root, start, stop);

		// 'c' clears the subtitles while this slide is up
		document.addEventListener("keydown", (e) => {
			if (e.key === "c" && !letterChip.closest("section.past, section.future")) typer.clear();
		});
	}
</script>

<style lang="scss">
	.fingerspell-demo {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.4em;
	}

	.viewport {
		position: relative;
		width: 58%;
		aspect-ratio: 16 / 9;
		border-radius: 12px;
		overflow: hidden;
		background: #06101d;
		box-shadow: 0 8px 30px rgb(0 0 0 / 0.5);

		video,
		canvas {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
			transform: scaleX(-1);
		}
	}

	.status[hidden],
	.letter-chip[hidden] {
		display: none;
	}

	.status {
		position: absolute;
		inset: 0;
		display: grid;
		place-items: center;
		margin: 0;
		font-size: 0.5em;
		color: #94a3b8;
	}

	.letter-chip {
		position: absolute;
		top: 0.4em;
		left: 0.5em;
		width: 1.8em;
		height: 1.8em;
		display: grid;
		place-items: center;
		background: rgb(0 0 0 / 0.65);
		border-radius: 50%;

		.letter {
			font-size: 0.9em;
			font-weight: bold;
			color: #4ade80;
		}

		.progress-ring {
			position: absolute;
			inset: 0;
			transform: rotate(-90deg);

			circle {
				fill: none;
				stroke: #4ade80;
				stroke-width: 2.5;
				stroke-linecap: round;
			}
		}
	}

	.subtitles {
		width: 70%;
		min-height: 1.6em;
		background: rgb(0 0 0 / 0.7);
		border-radius: 8px;
		padding: 0.15em 0.5em;

		.subtitle-text {
			margin: 0;
			font-size: 0.85em;
			letter-spacing: 0.08em;
			font-family: monospace;
		}
	}

	.samples-warning {
		font-size: 0.42em;
		color: #fbbf24;
		margin: 0;
	}
</style>
