---
import { withBase } from "../lib/paths";

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
	</head>

	<body>
		<slot />

		<script>
			import Reveal from "reveal.js";
			import RevealNotes from "reveal.js/plugin/notes/notes";
			import { registerDeck } from "../lib/deck";

			Reveal.initialize({
				transition: "none",
				history: true,
				autoAnimateDuration: 0.5,
				autoAnimateEasing: "cubic-bezier(0.4, 0, 0.2, 1)",
				plugins: [RevealNotes],
			}).then(() => registerDeck(Reveal));
		</script>
	</body>
</html>

<style is:global lang="scss">
	@import "reveal.js/dist/reveal.css";
	@import "reveal.js/dist/theme/night.css";
	@import "../../src/styles/highlightjs-theme-vs2015.css";

	// Explicit background on the root elements: in fullscreen, Chrome paints
	// the root canvas black instead of inheriting the body/theme background
	// (https://github.com/hakimel/reveal.js/issues/1516).
	html,
	body,
	.reveal-viewport {
		background: #0c1a2a;
	}

	main,
	.slide-background-content {
		background: linear-gradient(#133055, #0c1a2a);
	}
</style>
