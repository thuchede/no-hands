---
import Layout from "../layouts/Layout.astro";
import GestureHUD from "../components/GestureHUD.astro";
import Title from "../slides/Title.astro";
import Inspiration from "../slides/Inspiration.astro";
import PixelsToBodies from "../slides/PixelsToBodies.astro";
import UnderTheHood from "../slides/UnderTheHood.astro";
import DemoLandmarks from "../slides/DemoLandmarks.astro";
import LandmarksToMeaning from "../slides/LandmarksToMeaning.astro";
import DemoFingerspell from "../slides/DemoFingerspell.astro";
import GesturesToControl from "../slides/GesturesToControl.astro";
import DemoGestures from "../slides/DemoGestures.astro";
import NumberOne from "../slides/NumberOne.astro";
import NumberTwo from "../slides/NumberTwo.astro";
import NumberThree from "../slides/NumberThree.astro";
import Learnings from "../slides/Learnings.astro";
import QandA from "../slides/QandA.astro";
import Thanks from "../slides/Thanks.astro";
---

<Layout title="No Hands — camera body detection in the browser">
	<main class="reveal">
		<div class="slides">
			<Title />
			<Inspiration />
			<PixelsToBodies />
			<UnderTheHood />
			<DemoLandmarks />
			<LandmarksToMeaning />
			<DemoFingerspell />
			<GesturesToControl />
			<DemoGestures />
			<NumberOne />
			<NumberTwo />
			<NumberThree />
			<Learnings />
			<QandA />
			<Thanks />
		</div>
	</main>
	<GestureHUD />
</Layout>
