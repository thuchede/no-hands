---
import Slide from "../components/Slide.astro";
import GesturePractice from "../components/GesturePractice.astro";
---

<Slide animate={false}>
	<h2>🎥 Watch it watch you</h2>
	<GesturePractice />
	<aside class="notes">
		The badge shows what the gesture model sees in real time — open palm, fist, victory… Enable gesture control here
		and swipe: the next two slides are numbered so the audience can see the deck actually moving. Commands flash
		bottom-right of the video.
	</aside>
</Slide>
