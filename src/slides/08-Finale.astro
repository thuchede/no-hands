---
import Slide from "../components/Slide.astro";
import { currentEvent } from "../events";
---

<Slide animate={false}>
	<h2>No hands.</h2>
	<button class="enable-gestures" data-enable-gestures>🖐️ Enable gesture control</button>
	<p class="hint">…then put the clicker down.</p>
	<p class="links">
		<a href={currentEvent.someUrl}>{currentEvent.someUrl}</a>
	</p>
	<aside class="notes">
		Click the button (or press 'g'). The HUD appears bottom-right. Swipe back through the deck for questions — palm
		swipe to navigate, fist to get the overview. If detection goes sideways: press 'g' to turn it off, keyboard always
		works.
	</aside>
</Slide>

<script>
	import { gestureController } from "../lib/gestures";

	const button = document.querySelector<HTMLButtonElement>("[data-enable-gestures]");
	button?.addEventListener("click", () => gestureController.toggle());
	gestureController.addEventListener("state", (e) => {
		const enabled = (e as CustomEvent<{ enabled: boolean }>).detail.enabled;
		if (button) button.textContent = enabled ? "🖐️ Disable gesture control" : "🖐️ Enable gesture control";
	});
</script>

<style>
	.enable-gestures {
		font-size: 0.8em;
		font-family: inherit;
		padding: 0.5em 1em;
		border-radius: 12px;
		border: 2px solid #4ade80;
		background: rgb(74 222 128 / 0.12);
		color: #4ade80;
		cursor: pointer;

		&:hover {
			background: rgb(74 222 128 / 0.25);
		}
	}
	.hint {
		font-size: 0.55em;
		color: #94a3b8;
	}
	.links {
		margin-top: 1.5em;
		font-size: 0.5em;
	}
</style>
