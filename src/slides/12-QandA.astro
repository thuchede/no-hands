---
import Slide from "../components/Slide.astro";
---

<Slide animate={false}>
	<h1>Questions?</h1>
	<p class="hint">the deck is still listening — 🖐️ swipe to revisit any slide</p>
	<aside class="notes">
		Keep gesture mode on: answering a question by palm-swiping back to the relevant slide is the best possible closing
		argument. Press 'g' if you'd rather turn it off.
	</aside>
</Slide>

<style>
	.hint {
		font-size: 0.5em;
		color: #94a3b8;
	}
</style>
