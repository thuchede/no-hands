---
import Slide from "../components/Slide.astro";
---

<Slide animate={false}>
	<p class="big-number">1</p>
	<aside class="notes">Swipe demo slide — palm swipe left to go forward.</aside>
</Slide>

<style>
	.big-number {
		font-size: 14em;
		font-weight: bold;
		line-height: 1;
		margin: 0;
		color: #4ade80;
		text-shadow: 0 0 80px rgb(74 222 128 / 0.35);
	}
</style>
