---
import Slide from "../components/Slide.astro";
---

<Slide animate={false}>
	<p class="big-number">2</p>
	<aside class="notes">Swipe demo slide — swipe back and forth, then continue to the finale.</aside>
</Slide>

<style>
	.big-number {
		font-size: 14em;
		font-weight: bold;
		line-height: 1;
		margin: 0;
		color: #38bdf8;
		text-shadow: 0 0 80px rgb(56 189 248 / 0.35);
	}
</style>
